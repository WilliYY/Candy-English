# App
APP_HOST_BIND="127.0.0.1"
APP_PORT="3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-use-a-secure-random-value"
# Optional key for encrypting admin-only API/password records.
# If empty, AUTH_SECRET is used.
ADMIN_CREDENTIALS_SECRET=""
NODE_OPTIONS="--max_old_space_size=1024"
AVA_STORAGE_DIR="/app/storage"

# Protected upload optimization. PDF_MAX_UPLOAD_MB should stay below the
# Server Actions body limit configured in next.config.ts.
PDF_OPTIMIZATION_ENABLED="true"
PDF_OPTIMIZATION_PRESET="ebook"
PDF_MAX_UPLOAD_MB="14"

# Live class Jitsi host. Use "meet.jit.si" locally, or a dedicated host such as
# "meet.candyenglish.com.br" after DNS/HTTPS/Jitsi are configured.
NEXT_PUBLIC_LIVE_CLASS_JITSI_DOMAIN="meet.jit.si"

# Docker memory budget
APP_MEM_LIMIT="1536m"
APP_MEM_RESERVATION="512m"
POSTGRES_MEM_LIMIT="768m"
POSTGRES_MEM_RESERVATION="512m"
POSTGRES_SHM_SIZE="128mb"
POSTGRES_SHARED_BUFFERS="256MB"
POSTGRES_WORK_MEM="8MB"
POSTGRES_MAINTENANCE_WORK_MEM="128MB"
POSTGRES_EFFECTIVE_CACHE_SIZE="768MB"
POSTGRES_MAX_CONNECTIONS="50"
TOOLS_MEM_LIMIT="768m"
TOOLS_MEM_RESERVATION="256m"

# Optional AI helpers. Catty uses Gemini by default and OpenAI only when the
# message explicitly calls Catty by name; homework remains manual by default.
GEMINI_API_KEY=""
GEMINI_CATTY_MODEL="gemini-3.5-flash"
OPENAI_API_KEY=""
OPENAI_CATTY_MODEL="gpt-5.4-nano"
OPENAI_HOMEWORK_OCR_MODEL="gpt-4.1-mini"

# Optional Catty artifact enrichment. Normal chat never uses web search; this
# is only for Admin/Teacher preparation flows in "Estilo da Catty".
CATTY_ARTIFACT_ENRICHMENT_ENABLED="true"
CATTY_ARTIFACT_SEARCH_PROVIDER="offline"
CATTY_ARTIFACT_SEARCH_CACHE_DAYS="90"
BRAVE_SEARCH_API_KEY=""

# PostgreSQL container
POSTGRES_DB="candy_english"
POSTGRES_USER="candy_user"
POSTGRES_PASSWORD="change-me-local-password"

# Internal Docker Compose database URL
DATABASE_URL="postgresql://candy_user:change-me-local-password@postgres:5432/candy_english?schema=public"

# Initial admin seed
ADMIN_NAME="Candy Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-admin-password"
ADMIN_RESET_PASSWORD="false"

# Smoke tests
AUDIT_BASE_URL="http://localhost:3000"
