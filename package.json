{
  "name": "candy-english",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma generate && prisma db seed",
    "audit:server-smoke": "tsx scripts/server-smoke.ts",
    "audit:auth-smoke": "tsx scripts/auth-smoke.ts",
    "audit:avatar-smoke": "tsx scripts/avatar-smoke.ts",
    "verify:server-smoke": "docker compose --profile tools run --rm audit-server-smoke",
    "verify:auth-smoke": "docker compose --profile tools run --rm audit-server-smoke npm run audit:auth-smoke",
    "verify:avatar-smoke": "docker compose --profile tools run --rm audit-server-smoke npm run audit:avatar-smoke"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@radix-ui/react-slot": "1.2.4",
    "@tanstack/react-query": "5.100.9",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.2.3",
    "lucide-react": "0.555.0",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.16.3",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.75.0",
    "tailwind-merge": "3.4.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "24.10.2",
    "@types/pg": "8.16.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "15.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
