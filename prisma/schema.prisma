generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MaterialType {
  TEXT
  LINK
}

enum HomeworkStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  SUBMITTED
  REVIEWED
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              Role               @default(STUDENT)
  isActive          Boolean            @default(true)
  phone             String?
  address           String?
  avatarPath        String?
  avatarMimeType    String?
  studentProfile    StudentProfile?
  teacherProfile    TeacherProfile?
  financialLogs     FinancialLog[]
  sentChatMessages  ChatMessage[]
  uploadedContracts ContractDocument[] @relation("UploadedContracts")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([isActive])
}

model StudentProfile {
  id                 String                     @id @default(cuid())
  userId             String                     @unique
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  level              String?
  birthDate          DateTime?
  guardianDocument   String?
  gender             String?
  studentPhone       String?
  studentPhoneAlt    String?
  motherName         String?
  motherPhone        String?
  notes              String?
  chatThreads        ChatThread[]
  teacherAssignments StudentTeacherAssignment[] @relation("StudentAssignments")
  lessons            Lesson[]
  submissions        HomeworkSubmission[]
  contracts          ContractDocument[]
  liveSessions       LiveSession[]
}

model TeacherProfile {
  id                  String                     @id @default(cuid())
  userId              String                     @unique
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                 String?
  studentAssignments  StudentTeacherAssignment[] @relation("TeacherAssignments")
  chatThreads         ChatThread[]
  lessons             Lesson[]
  homeworks           Homework[]
  reviewedSubmissions HomeworkSubmission[]
  liveSessions        LiveSession[]
}

model StudentTeacherAssignment {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation("TeacherAssignments", fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation("StudentAssignments", fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([teacherProfileId, studentProfileId])
  @@index([studentProfileId])
}

model Lesson {
  id               String           @id @default(cuid())
  title            String
  description      String?
  scheduledAt      DateTime?
  status           LessonStatus     @default(PUBLISHED)
  teacherProfileId String
  teacherProfile   TeacherProfile   @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String?
  studentProfile   StudentProfile?  @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  materials        LessonMaterial[]
  vocabularyItems  VocabularyItem[]
  homeworks        Homework[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([teacherProfileId])
  @@index([studentProfileId])
  @@index([status])
}

model LessonMaterial {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  type      MaterialType @default(TEXT)
  content   String?
  url       String?
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([lessonId])
}

model VocabularyItem {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  term        String
  translation String
  example     String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([lessonId])
}

model Homework {
  id               String               @id @default(cuid())
  lessonId         String
  lesson           Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  teacherProfileId String
  teacherProfile   TeacherProfile       @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  title            String
  instructions     String?
  dueDate          DateTime?
  status           HomeworkStatus       @default(PUBLISHED)
  questions        HomeworkQuestion[]
  submissions      HomeworkSubmission[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([lessonId])
  @@index([teacherProfileId])
  @@index([status])
}

model HomeworkQuestion {
  id             String   @id @default(cuid())
  homeworkId     String
  homework       Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  prompt         String
  expectedAnswer String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([homeworkId])
}

model HomeworkSubmission {
  id                         String           @id @default(cuid())
  homeworkId                 String
  homework                   Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentProfileId           String
  studentProfile             StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  answers                    Json
  status                     SubmissionStatus @default(SUBMITTED)
  submittedAt                DateTime         @default(now())
  feedback                   String?
  reviewedAt                 DateTime?
  reviewedByTeacherProfileId String?
  reviewedByTeacherProfile   TeacherProfile?  @relation(fields: [reviewedByTeacherProfileId], references: [id], onDelete: SetNull)

  @@unique([homeworkId, studentProfileId])
  @@index([studentProfileId])
  @@index([status])
}

model LiveSession {
  id               String          @id @default(cuid())
  title            String
  meetUrl          String
  startsAt         DateTime?
  endsAt           DateTime?
  isLive           Boolean         @default(true)
  teacherProfileId String
  teacherProfile   TeacherProfile  @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([teacherProfileId])
  @@index([studentProfileId])
  @@index([isLive])
}

model ContractDocument {
  id               String          @id @default(cuid())
  title            String
  fileName         String
  storagePath      String
  mimeType         String
  sizeBytes        Int
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  uploadedByUserId String
  uploadedByUser   User            @relation("UploadedContracts", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())

  @@index([studentProfileId])
  @@index([uploadedByUserId])
}

model FinancialStudent {
  id            String             @id @default(cuid())
  name          String
  amountCents   Int
  paymentDay    Int
  paymentMethod String             @default("PIX")
  phone         String?
  cpf           String?
  email         String?
  address       String?
  payments      FinancialPayment[]
  logs          FinancialLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([paymentDay, name])
}

model FinancialPayment {
  id                    String           @id @default(cuid())
  year                  Int              @default(2026)
  month                 Int
  studentId             String
  student               FinancialStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isActive              Boolean          @default(true)
  snapshotName          String
  snapshotAmountCents   Int
  snapshotPaymentDay    Int
  snapshotPaymentMethod String           @default("PIX")
  snapshotPhone         String?
  snapshotCpf           String?
  snapshotEmail         String?
  snapshotAddress       String?
  isPaid                Boolean          @default(false)
  paidAt                DateTime?
  note                  String?
  logs                  FinancialLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([studentId, year, month])
  @@index([year, month, isActive])
  @@index([year, month, isPaid])
  @@index([isPaid])
}

model FinancialLog {
  id              String            @id @default(cuid())
  action          String
  description     String
  studentId       String?
  student         FinancialStudent? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  paymentId       String?
  payment         FinancialPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdByUser   User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())

  @@index([createdAt])
  @@index([studentId])
}

model SitePageContent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  ctaLabel    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatThread {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([teacherProfileId, studentProfileId])
  @@index([studentProfileId])
}

model ChatMessage {
  id           String     @id @default(cuid())
  threadId     String
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  senderUser   User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime   @default(now())

  @@index([threadId, createdAt])
  @@index([senderUserId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([success, createdAt])
}
