generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum StudentPreRegistrationStatus {
  PENDING
  CONTACTED
  APPROVED
  REJECTED
}

enum CandyXpEventKind {
  ADMIN_ROUTINE
  BADGE_AWARDED
  CANDY_XP_ACTIVITY_COMPLETED
  FEEDBACK_REVIEWED
  HOMEWORK_SUBMITTED
  LESSON_ACTIVITY_SUBMITTED
  MISSION_COMPLETED
  PROFILE_READY
  STREAK_BONUS
  TEACHER_ROUTINE
}

enum CandyMissionKind {
  ADMIN_ROUTINE
  DAILY
  FEEDBACK
  GAME
  HOMEWORK
  LESSON
  LISTENING
  REVIEW
  SPEAKING
  VOCABULARY
}

enum CandyXpActivityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CandyXpQuestionType {
  SHORT_TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
  CHECKBOX
  MATCHING
}

enum CandyXpSubmissionStatus {
  DRAFT
  SUBMITTED
  RETURNED
  REVIEWED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MaterialType {
  TEXT
  LINK
}

enum HomeworkStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum HomeworkKind {
  TEXT
  INTERACTIVE
}

enum HomeworkFieldType {
  SHORT_TEXT
  LONG_TEXT
  CHECKBOX
  DRAWING
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  RETURNED
  REVIEWED
}

enum AgendaLessonStatus {
  SCHEDULED
  ATTENDED
  MISSED
  MAKEUP_SCHEDULED
  MAKEUP_ATTENDED
}

enum AdminCredentialKind {
  API_KEY
  PASSWORD
  TOKEN
  CONFIG
  URL
  OTHER
}

enum AdminCredentialSource {
  MANUAL
  ENV
}

enum CattyMessageRole {
  USER
  CATTY
}

enum CattyReplySource {
  GEMINI
  OPENAI
  FALLBACK
}

enum CattyLearningCategory {
  PERSONALITY_RULE
  IDEAL_REPLY
  BAD_REPLY
  VOCABULARY
  COMMON_QUESTION
  HOMEWORK_EXAMPLE
  TEACHER_GUIDANCE
  STUDENT_GUIDANCE
  CATTY_PHRASE
  APPROVED_CORRECTION
  CANDY_CONTEXT
}

enum CattyLearningStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum CattyLearningFeedbackKind {
  LIKED
  DISLIKED
  CONFUSING
  SHOULD_ANSWER
  PATTERN_SUGGESTION
}

enum CattyUserMemoryCategory {
  INTEREST
  LEARNING_GOAL
  DIFFICULTY
  STYLE
  FAVORITE_THEME
  EMOJI_PREFERENCE
  NOTE
}

enum CattyUserMemorySource {
  USER_MESSAGE
  TEACHER_NOTE
  ADMIN_NOTE
  CATTY_DETECTED
}

enum CattyUserMemoryStatus {
  ACTIVE
  PENDING
  FLAGGED
  ARCHIVED
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  passwordHash         String
  sessionVersion       Int                   @default(0)
  role                 Role                  @default(STUDENT)
  isActive             Boolean               @default(true)
  phone                String?
  address              String?
  avatarPath           String?
  avatarMimeType       String?
  studentProfile       StudentProfile?
  teacherProfile       TeacherProfile?
  financialLogs        FinancialLog[]
  agendaLogs           AgendaLog[]
  createdCredentials   AdminCredential[]     @relation("AdminCredentialCreatedBy")
  updatedCredentials   AdminCredential[]     @relation("AdminCredentialUpdatedBy")
  createdCandyXpActivities CandyXpActivity[] @relation("CandyXpActivityCreatedBy")
  reviewedCandyXpSubmissions CandyXpActivitySubmission[] @relation("CandyXpSubmissionReviewedBy")
  reviewedStudentPreRegistrations StudentPreRegistration[] @relation("StudentPreRegistrationReviewedBy")
  convertedStudentPreRegistration StudentPreRegistration? @relation("StudentPreRegistrationConvertedUser")
  candyXpProfile       CandyXpProfile?
  candyXpEvents        CandyXpEvent[]
  candyBadges          CandyUserBadge[]
  candyMissionAttempts CandyMissionAttempt[]
  cattyConversations   CattyConversation[]
  createdCattyLearningItems CattyLearningItem[] @relation("CattyLearningItemCreatedBy")
  approvedCattyLearningItems CattyLearningItem[] @relation("CattyLearningItemApprovedBy")
  createdCattyLearningFeedbacks CattyLearningFeedback[] @relation("CattyLearningFeedbackCreatedBy")
  reviewedCattyLearningFeedbacks CattyLearningFeedback[] @relation("CattyLearningFeedbackReviewedBy")
  cattyUserMemories    CattyUserMemory[]    @relation("CattyUserMemoryUser")
  createdCattyUserMemories CattyUserMemory[] @relation("CattyUserMemoryCreatedBy")
  cattyMemoryEvents    CattyMemoryEvent[]   @relation("CattyMemoryEventUser")
  createdCattyMemoryEvents CattyMemoryEvent[] @relation("CattyMemoryEventCreatedBy")
  sentChatMessages     ChatMessage[]
  uploadedContracts    ContractDocument[]    @relation("UploadedContracts")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([isActive])
}

model StudentProfile {
  id                 String                     @id @default(cuid())
  userId             String                     @unique
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  level              String?
  birthDate          DateTime?
  guardianDocument   String?
  gender             String?
  studentPhone       String?
  studentPhoneAlt    String?
  motherName         String?
  motherPhone        String?
  notes              String?
  chatThreads        ChatThread[]
  teacherAssignments StudentTeacherAssignment[] @relation("StudentAssignments")
  lessons            Lesson[]
  submissions        HomeworkSubmission[]
  candyXpAssignments CandyXpActivityAssignment[]
  candyXpSubmissions CandyXpActivitySubmission[]
  contracts          ContractDocument[]
  liveSessions       LiveSession[]
}

model StudentPreRegistration {
  id               String                       @id @default(cuid())
  status           StudentPreRegistrationStatus @default(PENDING)
  fullName         String
  email            String                       @unique
  phone            String
  address          String?
  birthDate        DateTime?
  studentPhone     String?
  secondaryContact String?
  guardianDocument String?
  guardianName     String?
  guardianPhone    String?
  notes            String?
  englishGoal      String
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   User?                        @relation("StudentPreRegistrationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  convertedUserId  String?                      @unique
  convertedUser    User?                        @relation("StudentPreRegistrationConvertedUser", fields: [convertedUserId], references: [id], onDelete: SetNull)
  statusNote       String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([reviewedByUserId])
  @@index([convertedUserId])
}

model TeacherProfile {
  id                  String                     @id @default(cuid())
  userId              String                     @unique
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                 String?
  studentAssignments  StudentTeacherAssignment[] @relation("TeacherAssignments")
  chatThreads         ChatThread[]
  lessons             Lesson[]
  homeworks           Homework[]
  reviewedSubmissions HomeworkSubmission[]
  liveSessions        LiveSession[]
}

model StudentTeacherAssignment {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation("TeacherAssignments", fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation("StudentAssignments", fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([teacherProfileId, studentProfileId])
  @@index([studentProfileId])
}

model Lesson {
  id               String           @id @default(cuid())
  title            String
  description      String?
  scheduledAt      DateTime?
  status           LessonStatus     @default(PUBLISHED)
  teacherProfileId String
  teacherProfile   TeacherProfile   @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String?
  studentProfile   StudentProfile?  @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  materials        LessonMaterial[]
  vocabularyItems  VocabularyItem[]
  homeworks        Homework[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([teacherProfileId])
  @@index([studentProfileId])
  @@index([status])
}

model LessonMaterial {
  id        String       @id @default(cuid())
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  type      MaterialType @default(TEXT)
  content   String?
  url       String?
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([lessonId])
}

model VocabularyItem {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  term        String
  translation String
  example     String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([lessonId])
}

model Homework {
  id                   String                     @id @default(cuid())
  lessonId             String
  lesson               Lesson                     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  teacherProfileId     String
  teacherProfile       TeacherProfile             @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  title                String
  instructions         String?
  dueDate              DateTime?
  kind                 HomeworkKind               @default(TEXT)
  assetFileName        String?
  assetStoragePath     String?
  assetMimeType        String?
  assetSizeBytes       Int?
  assetPageCount       Int                        @default(1)
  fieldDetectionSource String?
  interactiveFields    HomeworkInteractiveField[]
  status               HomeworkStatus             @default(PUBLISHED)
  questions            HomeworkQuestion[]
  submissions          HomeworkSubmission[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([lessonId])
  @@index([teacherProfileId])
  @@index([kind])
  @@index([status])
}

model HomeworkInteractiveField {
  id          String            @id @default(cuid())
  homeworkId  String
  homework    Homework          @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  type        HomeworkFieldType @default(LONG_TEXT)
  label       String?
  placeholder String?
  page        Int               @default(1)
  x           Float
  y           Float
  width       Float
  height      Float
  required    Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([homeworkId])
}

model HomeworkQuestion {
  id             String   @id @default(cuid())
  homeworkId     String
  homework       Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  prompt         String
  expectedAnswer String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([homeworkId])
}

model HomeworkSubmission {
  id                         String           @id @default(cuid())
  homeworkId                 String
  homework                   Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentProfileId           String
  studentProfile             StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  answers                    Json
  status                     SubmissionStatus @default(SUBMITTED)
  submittedAt                DateTime         @default(now())
  feedback                   String?
  reviewedAt                 DateTime?
  reviewedByTeacherProfileId String?
  reviewedByTeacherProfile   TeacherProfile?  @relation(fields: [reviewedByTeacherProfileId], references: [id], onDelete: SetNull)

  @@unique([homeworkId, studentProfileId])
  @@index([studentProfileId])
  @@index([status])
}

model LiveSession {
  id               String          @id @default(cuid())
  title            String
  meetUrl          String
  startsAt         DateTime?
  endsAt           DateTime?
  isLive           Boolean         @default(true)
  teacherProfileId String
  teacherProfile   TeacherProfile  @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([teacherProfileId])
  @@index([studentProfileId])
  @@index([isLive])
}

model ContractDocument {
  id               String          @id @default(cuid())
  title            String
  fileName         String
  storagePath      String
  mimeType         String
  sizeBytes        Int
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  uploadedByUserId String
  uploadedByUser   User            @relation("UploadedContracts", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())

  @@index([studentProfileId])
  @@index([uploadedByUserId])
}

model FinancialStudent {
  id            String             @id @default(cuid())
  name          String
  amountCents   Int
  paymentDay    Int
  paymentMethod String             @default("PIX")
  phone         String?
  cpf           String?
  email         String?
  address       String?
  payments      FinancialPayment[]
  logs          FinancialLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([paymentDay, name])
}

model FinancialPayment {
  id                    String           @id @default(cuid())
  year                  Int              @default(2026)
  month                 Int
  studentId             String
  student               FinancialStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isActive              Boolean          @default(true)
  snapshotName          String
  snapshotAmountCents   Int
  snapshotPaymentDay    Int
  snapshotPaymentMethod String           @default("PIX")
  snapshotPhone         String?
  snapshotCpf           String?
  snapshotEmail         String?
  snapshotAddress       String?
  isPaid                Boolean          @default(false)
  paidAt                DateTime?
  note                  String?
  logs                  FinancialLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([studentId, year, month])
  @@index([year, month, isActive])
  @@index([year, month, isPaid])
  @@index([isPaid])
}

model FinancialLog {
  id              String            @id @default(cuid())
  action          String
  description     String
  studentId       String?
  student         FinancialStudent? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  paymentId       String?
  payment         FinancialPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdByUser   User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())

  @@index([createdAt])
  @@index([studentId])
}

model AgendaStudent {
  id        String         @id @default(cuid())
  name      String
  phone     String?
  notes     String?
  lessons   AgendaLesson[]
  logs      AgendaLog[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([name])
}

model AgendaLesson {
  id                String             @id @default(cuid())
  year              Int                @default(2026)
  month             Int
  date              DateTime
  weekday           Int
  time              String
  studentId         String
  student           AgendaStudent      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  isActive          Boolean            @default(true)
  isMakeup          Boolean            @default(false)
  makeupForLessonId String?
  makeupForLesson   AgendaLesson?      @relation("AgendaMakeup", fields: [makeupForLessonId], references: [id], onDelete: SetNull)
  makeupLessons     AgendaLesson[]     @relation("AgendaMakeup")
  status            AgendaLessonStatus @default(SCHEDULED)
  notes             String?
  logs              AgendaLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([year, month, date])
  @@index([studentId, year, month])
  @@index([isActive, date])
  @@index([makeupForLessonId])
}

model AgendaLog {
  id              String         @id @default(cuid())
  action          String
  description     String
  studentId       String?
  student         AgendaStudent? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  lessonId        String?
  lesson          AgendaLesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdByUser   User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([createdAt])
  @@index([studentId])
}

model SitePageContent {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  ctaLabel    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminCredential {
  id               String                @id @default(cuid())
  label            String
  service          String
  kind             AdminCredentialKind   @default(API_KEY)
  username         String?
  url              String?
  notes            String?
  secretCiphertext String
  secretDigest     String
  secretPreview    String
  source           AdminCredentialSource @default(MANUAL)
  sourceKey        String?               @unique
  createdByUserId  String?
  createdByUser    User?                 @relation("AdminCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId  String?
  updatedByUser    User?                 @relation("AdminCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([service])
  @@index([kind])
  @@index([source])
  @@index([createdAt])
}

model CandyXpProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              Role
  totalXp           Int       @default(0)
  level             Int       @default(1)
  levelStartXp      Int       @default(0)
  progressXp        Int       @default(0)
  requiredXp        Int       @default(120)
  streakDays        Int       @default(0)
  longestStreakDays Int       @default(0)
  lastActivityDate  DateTime?
  lastXpEventAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([role, level])
  @@index([totalXp])
  @@index([lastXpEventAt])
}

model CandyXpEvent {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role
  kind        CandyXpEventKind
  sourceKey   String
  sourceLabel String
  xp          Int
  metadata    Json?
  occurredAt  DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@unique([userId, sourceKey])
  @@index([userId, occurredAt])
  @@index([role, kind])
  @@index([sourceLabel])
}

model CandyBadgeDefinition {
  id                 String            @id @default(cuid())
  key                String            @unique
  role               Role?
  title              String
  description        String
  icon               String?
  requiredLevel      Int?
  requiredEventKind  CandyXpEventKind?
  requiredEventCount Int?
  requiredStreakDays Int?
  isActive           Boolean           @default(true)
  earnedBadges       CandyUserBadge[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([role, isActive])
  @@index([requiredEventKind])
}

model CandyUserBadge {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeDefinitionId String
  badgeDefinition   CandyBadgeDefinition @relation(fields: [badgeDefinitionId], references: [id], onDelete: Cascade)
  earnedAt          DateTime             @default(now())
  sourceEventId     String?

  @@unique([userId, badgeDefinitionId])
  @@index([userId, earnedAt])
  @@index([badgeDefinitionId])
}

model CandyMission {
  id            String                @id @default(cuid())
  key           String                @unique
  role          Role?
  title         String
  description   String
  kind          CandyMissionKind
  xpReward      Int
  targetCount   Int                   @default(1)
  repeatable    Boolean               @default(false)
  cooldownHours Int?
  isActive      Boolean               @default(true)
  sortOrder     Int                   @default(0)
  attempts      CandyMissionAttempt[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([role, isActive, sortOrder])
  @@index([kind, isActive])
}

model CandyMissionAttempt {
  id            String       @id @default(cuid())
  attemptKey    String       @unique
  missionId     String
  mission       CandyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceKey     String
  progressCount Int          @default(0)
  completedAt   DateTime?
  xpEventId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([missionId, userId])
  @@index([userId, completedAt])
}

model CandyXpActivity {
  id               String                     @id @default(cuid())
  title            String
  description      String?
  level            String
  category         String
  xpReward         Int
  status           CandyXpActivityStatus      @default(DRAFT)
  assetFileName    String?
  assetStoragePath String?
  assetMimeType    String?
  assetSizeBytes   Int?
  assetPageCount   Int                        @default(1)
  publishedAt      DateTime?
  createdByUserId  String?
  createdByUser    User?                      @relation("CandyXpActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  questions        CandyXpActivityQuestion[]
  assignments      CandyXpActivityAssignment[]
  submissions      CandyXpActivitySubmission[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([status, category])
  @@index([level])
  @@index([createdByUserId])
}

model CandyXpActivityQuestion {
  id            String               @id @default(cuid())
  activityId    String
  activity      CandyXpActivity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  type          CandyXpQuestionType
  prompt        String
  options       Json?
  correctAnswer Json?
  required      Boolean              @default(true)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([activityId, sortOrder])
}

model CandyXpActivityAssignment {
  id               String           @id @default(cuid())
  activityId       String
  activity         CandyXpActivity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  assignedAt       DateTime         @default(now())

  @@unique([activityId, studentProfileId])
  @@index([studentProfileId])
}

model CandyXpActivitySubmission {
  id                 String                  @id @default(cuid())
  activityId         String
  activity           CandyXpActivity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  studentProfileId   String
  studentProfile     StudentProfile          @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  answers            Json
  status             CandyXpSubmissionStatus @default(DRAFT)
  autoScorePercent   Int?
  feedback           String?
  awardedXp          Int?
  xpEventId          String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedByUserId   String?
  reviewedByUser     User?                   @relation("CandyXpSubmissionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([activityId, studentProfileId])
  @@index([studentProfileId, status])
  @@index([activityId, status])
  @@index([reviewedByUserId])
}

model CattyConversation {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  area       String
  task       String?
  contextKey String
  messages   CattyMessage[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, contextKey])
  @@index([userId, updatedAt])
}

model CattyMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   CattyConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           CattyMessageRole
  text           String
  source         CattyReplySource?
  learningFeedbacks CattyLearningFeedback[]
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
}

model CattyLearningItem {
  id               String                @id @default(cuid())
  title            String
  category         CattyLearningCategory
  intent           String?
  userPrompt       String?
  badReply         String?
  idealReply       String?
  notes            String?
  tags             String[]              @default([])
  status           CattyLearningStatus   @default(PENDING)
  createdByUserId  String?
  createdByUser    User?                 @relation("CattyLearningItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUserId String?
  approvedByUser   User?                 @relation("CattyLearningItemApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  feedbacks        CattyLearningFeedback[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([status, category])
  @@index([intent])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@index([createdAt])
}

model CattyLearningFeedback {
  id                String                 @id @default(cuid())
  itemId            String?
  item              CattyLearningItem?     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  kind              CattyLearningFeedbackKind @default(PATTERN_SUGGESTION)
  cattyMessageId    String?
  cattyMessage      CattyMessage?          @relation(fields: [cattyMessageId], references: [id], onDelete: SetNull)
  note              String
  suggestedTitle    String?
  suggestedCategory CattyLearningCategory?
  suggestedIntent   String?
  userPrompt        String?
  cattyReply        String?
  idealReply        String?
  contextArea       String?
  contextTask       String?
  contextKey        String?
  status            CattyLearningStatus    @default(PENDING)
  createdByUserId   String?
  createdByUser     User?                  @relation("CattyLearningFeedbackCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUserId  String?
  reviewedByUser    User?                  @relation("CattyLearningFeedbackReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([kind, status])
  @@index([itemId])
  @@index([cattyMessageId])
  @@index([contextKey])
  @@index([createdByUserId])
  @@index([reviewedByUserId])
}

model CattyUserMemory {
  id              String                    @id @default(cuid())
  userId          String
  user            User                      @relation("CattyUserMemoryUser", fields: [userId], references: [id], onDelete: Cascade)
  category        CattyUserMemoryCategory
  key             String
  value           String
  confidence      Int                       @default(70)
  source          CattyUserMemorySource     @default(CATTY_DETECTED)
  status          CattyUserMemoryStatus     @default(PENDING)
  flaggedReason   String?
  createdByUserId String?
  createdByUser   User?                     @relation("CattyUserMemoryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lastUsedAt      DateTime?
  usageCount      Int                       @default(0)
  events          CattyMemoryEvent[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([userId, category, key])
  @@index([userId, status, category])
  @@index([createdByUserId])
  @@index([status, updatedAt])
}

model CattyMemoryEvent {
  id              String                    @id @default(cuid())
  memoryId        String?
  memory          CattyUserMemory?          @relation(fields: [memoryId], references: [id], onDelete: SetNull)
  userId          String
  user            User                      @relation("CattyMemoryEventUser", fields: [userId], references: [id], onDelete: Cascade)
  category        CattyUserMemoryCategory?
  key             String?
  previousValue   String?
  nextValue       String?
  action          String
  source          CattyUserMemorySource
  status          CattyUserMemoryStatus?
  note            String?
  createdByUserId String?
  createdByUser   User?                     @relation("CattyMemoryEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime                  @default(now())

  @@index([userId, createdAt])
  @@index([memoryId])
  @@index([createdByUserId])
}

model ChatThread {
  id               String         @id @default(cuid())
  teacherProfileId String
  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([teacherProfileId, studentProfileId])
  @@index([studentProfileId])
}

model ChatMessage {
  id           String     @id @default(cuid())
  threadId     String
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUserId String
  senderUser   User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime   @default(now())

  @@index([threadId, createdAt])
  @@index([senderUserId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([success, createdAt])
}
